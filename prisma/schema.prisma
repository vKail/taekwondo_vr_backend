generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username  String
  password  String
  name      String?
  lastName  String?
  birthdate DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  gameSessions GameSession[]
  sessions     Session[]
}

model ReferenceMovement {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GameSession {
  id          Int      @id @default(autoincrement())
  userId      Int
  score       Float
  startedAt   DateTime
  endedAt     DateTime
  
  records     SessionRecord[]
  
  user        User     @relation(fields: [userId], references: [id])
}

model SessionRecord {
  id              Int      @id @default(autoincrement())
  gameSessionId   Int
  movementName    String
  executionData   Json
  accuracy        Float
  
  gameSession     GameSession @relation(fields: [gameSessionId], references: [id])
}

enum SessionStatus {
  ACTIVE
  COMPLETED
}

model Session {
  id          Int           @id @default(autoincrement())
  userId      Int
  score       Float         @default(0)
  status      SessionStatus @default(ACTIVE)
  startedAt   DateTime      @default(now())
  endedAt     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([userId])
  user        User          @relation(fields: [userId], references: [id])
  details     SessionDetail[]
}

model SessionDetail {
  id              Int      @id @default(autoincrement())
  sessionId       Int
  movementId     Int?
  movementName   String
  executionData  Json?
  feedback       Json?
  accuracy       Float?
  order          Int
  createdAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([sessionId])
  session        Session   @relation(fields: [sessionId], references: [id])
}
